# App
APP_ENV=development
APP_SECRET_KEY=change-me-minimum-32-chars-for-hs256-signing
APP_CORS_ORIGINS=http://localhost:4200

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=itransfer

# JWT
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# Fernet key for provider-token encryption at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Spotify (https://developer.spotify.com/documentation/web-api)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/spotify/callback

# YouTube / Google (https://developers.google.com/youtube/v3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/youtube/callback

# Apple Music (https://developer.apple.com/documentation/applemusicapi/)
# Developer token is a JWT signed with the Apple private key (.p8)
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./secrets/AuthKey.p8
APPLE_STOREFRONT=us

# Amazon Music (placeholder — to be implemented)
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/amazon/callback

# Deezer (deprioritized — implement last)
DEEZER_APP_ID=
DEEZER_APP_SECRET=
DEEZER_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/deezer/callback
