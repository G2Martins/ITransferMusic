# =========================================================
# ITransferMusic - Backend (.env.example)
# Copie este arquivo para .env e preencha com seus valores.
# NUNCA faca commit do arquivo .env real.
# =========================================================

# --- Aplicacao ---
APP_NAME=ITransferMusic
APP_ENV=development
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:4200"]

# --- Seguranca / JWT ---
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=troque-este-valor-por-um-segredo-forte
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Chave Fernet para cifrar tokens de provedores no MongoDB.
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROVIDER_TOKEN_ENCRYPTION_KEY=

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=itransfermusic

# --- Spotify ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:4200/auth/callback/spotify

# --- YouTube / Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4200/auth/callback/google

# --- Apple Music ---
# Developer Token: JWT gerado a partir da AuthKey (.p8) no Apple Developer.
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PATH=./secrets/AuthKey.p8
APPLE_MUSIC_STOREFRONT=us

# --- Amazon Music (placeholder - API e restrita) ---
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REDIRECT_URI=

# --- Deezer (descopado inicialmente) ---
# DEEZER_APP_ID=
# DEEZER_APP_SECRET=
